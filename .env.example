# Audio RAG Environment Variables Example
# Copy this file to .env and customize as needed

# ============================================
# Qdrant Vector Database Configuration
# ============================================
# Hostname for Qdrant service
# Use "localhost" for local development
# Use "qdrant" when running inside Docker Compose
QDRANT_HOST=localhost

# Port for Qdrant service
QDRANT_PORT=6333

# ============================================
# Triton Server Detection
# ============================================
# Set to "true" when running inside Triton server
# This affects which implementations are used (direct vs HTTP clients)
TRITON_SERVER=false

# ============================================
# ASR (Automatic Speech Recognition) Settings
# ============================================
# Whisper model size: tiny, base, small, medium, large
AUDIO_RAG_ASR_MODEL_SIZE=tiny

# Compute type: int8, int16, float16, float32
AUDIO_RAG_ASR_COMPUTE_TYPE=int8

# Device: cpu, cuda
AUDIO_RAG_ASR_DEVICE=cpu

# Enable VAD (Voice Activity Detection) filter
AUDIO_RAG_ASR_VAD_FILTER=true

# ============================================
# LLM (Large Language Model) Settings
# ============================================
# Enable LLM for answer generation
AUDIO_RAG_USE_LLM=true

# LLM model name (HuggingFace model ID)
AUDIO_RAG_LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# Device for LLM inference: cpu, cuda
AUDIO_RAG_LLM_DEVICE=cpu

# Maximum tokens for LLM generation
AUDIO_RAG_LLM_MAX_TOKENS=512

# ============================================
# Triton Server URLs (for client usage)
# ============================================
# Base URL for Triton HTTP API
# Use "http://localhost:8000" for local development
# Use "http://triton:8000" when running inside Docker Compose
TRITON_BASE_URL=http://localhost:8000
