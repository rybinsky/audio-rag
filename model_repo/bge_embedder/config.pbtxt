name: "bge_embedder"
backend: "python"
max_batch_size: 32

input [
  {
    name: "INPUT_TEXT"
    data_type: TYPE_STRING
    dims: [ 1 ]
  }
]

output [
  {
    name: "OUTPUT_EMBEDDING"
    data_type: TYPE_FP32
    dims: [ 1024 ]
  }
]

instance_group [
  {
    count: 1
    kind: KIND_CPU
  }
]

parameters [
  {
    key: "EXECUTION_ENV_PATH"
    value: { string_value: "/workspace/.venv" }
  }
]

dynamic_batching {
  preferred_batch_size: [ 8, 16, 32 ]
  max_queue_delay_microseconds: 100
}
